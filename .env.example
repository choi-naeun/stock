# =========================
# stock-tracker вҖ” .env.example
# =========================
# placeholderл§Ң л‘”лӢӨ. мӢӨм ң к°’мқҖ .env.local м—җ (gitignore лҗЁ).
# м ҲлҢҖ мқҙ нҢҢмқјм—җ м§„м§ң нӮӨлҘј л„Јм§Җ л§җ кІғ.

# ---- кіөнҶө ----
NODE_ENV=development

# ---- Supabase ----
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- API (NestJS) ----
API_PORT=3001
WEB_ORIGIN=http://localhost:3000

# ---- LLM: Google Gemini 1.5 Flash (л¬ҙлЈҢ, лӢЁмқј кіөкёүмһҗ) ----
# https://aistudio.google.com/app/apikey  (кІ°м ңмҲҳлӢЁ лҜёл“ұлЎқмңјлЎң л¬ҙлЈҢ н”Ңлһң мң м§Җ)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Upstash Redis (л¬ҙлЈҢ) ----
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Google OAuth (Supabase Auth Providerм—җ м§Ғм ‘ л“ұлЎқ) ----
# Supabase Dashboard > Authentication > Providers > Google
# мӢӨм ң нӮӨлҠ” Supabase мҪҳмҶ”м—җл§Ң м ҖмһҘ, м—¬кё° л‘җм§Җ м•ҠлҠ”лӢӨ.

# ---- DART Open API (көӯлӮҙ кіөмӢң) ----
# https://opendart.fss.or.kr/
DART_API_KEY=

# ---- FMP (Financial Modeling Prep) л¬ҙлЈҢ н”Ңлһң вҖ” Phase 1B мһ¬л¬ҙм§Җн‘ң ----
# https://site.financialmodelingprep.com/developer/docs вҖ” 250 req/day
FMP_API_KEY=

# ---- SEC EDGAR вҖ” н•ҙмҷё кіөмӢң ----
# нӮӨ л¶Ҳмҡ”. User-Agent н—ӨлҚ”л§Ң к·ңм • мӨҖмҲҳ.
SEC_EDGAR_USER_AGENT="stock-tracker (admin@example.com)"

# ---- RSS мҶҢмҠӨ (IngestionModule) ----
# кө¬л¶„мһҗ: мүјн‘ң. кіөмӢқ RSSл§Ң мӮ¬мҡ©.
RSS_SOURCES_KR="https://www.yna.co.kr/rss/economy.xml,https://www.hankyung.com/feed/economy,https://rss.mt.co.kr/mt_stock.xml"
RSS_SOURCES_GLOBAL="https://finance.yahoo.com/news/rssindex,https://seekingalpha.com/market_currents.xml"

# ---- мҡҙмҳҒ м•ҢлҰј (м„ нғқ) ----
# Slack Incoming Webhook. л№„мӣҢл‘җл©ҙ м•ҢлҰјмқҖ мҪҳмҶ” лЎңк·ёлЎңл§Ң.
# https://api.slack.com/messaging/webhooks
OPS_SLACK_WEBHOOK=

# ---- Cron ліҙм•Ҳ нҶ нҒ° (л°°нҸ¬ нҷҳкІҪ) ----
# GitHub Actions cronмқҙ /api/cron/daily нҳём¶ң мӢң Bearer н—ӨлҚ”лЎң мӮ¬мҡ©.
# Render render.yaml мқҳ generateValue лЎң мһҗлҸҷ мғқм„ұлҗҳкұ°лӮҳ, 32мһҗ мқҙмғҒ мһ„мқҳ л¬ёмһҗм—ҙ л“ұлЎқ.
CRON_SECRET=

# ---- кҙҖлҰ¬мһҗ ----
ADMIN_EMAIL=admin@example.com
